    {
      "id": 5,
      "type": "timeseries",
      "title": "Error Ratio by Service (5xx)",
      "description": "Fraction of requests returning 5xx (RED: Errors).",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum by (job) (rate(http_requests_total{job=~\"api-gateway|fhir-server|ml-serving|audit-service|wearables-ingester|dicom-receiver\", status=~\"5..\"}[5m])) / clamp_min(sum by (job) (rate(http_requests_total{job=~\"api-gateway|fhir-server|ml-serving|audit-service|wearables-ingester|dicom-receiver\"}[5m])), 0.001)",
          "legendFormat": "{{job}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"fhir-server\", status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"fhir-server\"}[5m])), 0.001)",
          "legendFormat": "fhir-server",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "",
            "axisPlacement": "auto",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
