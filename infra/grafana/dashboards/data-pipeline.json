          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "max by (topic, consumergroup) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}} / {{topic}}",
          "refId": "A"
