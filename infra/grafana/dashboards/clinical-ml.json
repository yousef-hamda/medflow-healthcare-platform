{
  "uid": "medflow-clinical-ml",
  "title": "MedFlow / Clinical ML",
  "description": "Sepsis early-warning model: serving volume, latency, alert rate vs incidence, and AUROC over time.",
  "tags": [
    "medflow",
    "ml",
    "clinical"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Prediction Serving",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prediction Volume by Model",
      "description": "Predictions served per second, by model and version.",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum by (model, model_version) (rate(medflow_predictions_total[5m]))",
          "legendFormat": "{{model}} {{model_version}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "",
            "axisPlacement": "auto",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Inference Latency (ml-serving)",
      "description": "End-to-end model inference latency including feature fetch.",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(medflow_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(medflow_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(medflow_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "",
            "axisPlacement": "auto",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Sepsis Early Warning",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Sepsis Alert Rate vs Confirmed Incidence",
      "description": "Alert volume against chart-confirmed incidence. Divergence = drift or threshold miscalibration; compare against the 24h baseline series.",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(rate(medflow_sepsis_alerts_total[1h]))",
          "legendFormat": "alerts fired",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(rate(medflow_sepsis_confirmed_total[1h]))",
          "legendFormat": "confirmed sepsis (chart-validated)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(rate(medflow_sepsis_alerts_total[1h] offset 24h))",
          "legendFormat": "alerts fired (24h ago baseline)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "",
            "axisPlacement": "auto",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Alert Precision Proxy (confirmed / fired, 6h window)",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(increase(medflow_sepsis_confirmed_total[6h])) / clamp_min(sum(increase(medflow_sepsis_alerts_total[6h])), 1)",
          "legendFormat": "precision proxy",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "",
            "axisPlacement": "auto",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
