    {
      "id": 8,
      "type": "timeseries",
      "title": "AUROC Over Time (pushed from ml-batch evaluation)",
      "description": "Rolling AUROC computed by the nightly ml-batch evaluation job and pushed via OTLP. Alert threshold for retraining review: 0.80.",
