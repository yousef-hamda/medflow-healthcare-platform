    {
      "id": 4,
      "type": "row",
      "title": "Break-Glass & Chain Integrity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Break-Glass Accesses (24h)",
      "description": "Emergency PHI access overrides in the last 24h. Every one requires retrospective review.",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "sum(increase(medflow_break_glass_access_total[24h]))",
          "legendFormat": "break-glass",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Audit Chain Verification",
      "description": "Periodic hash-chain verification over the audit log. FAIL = potential tampering \u2014 follow the IR runbook.",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "min(medflow_audit_chain_verification_success)",
          "legendFormat": "chain",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "VERIFIED",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Last WORM Export",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "medflow-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 10
