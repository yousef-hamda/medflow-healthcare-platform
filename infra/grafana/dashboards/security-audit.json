    {
      "id": 13,
      "type": "logs",
      "title": "audit-service Logs (Loki)",
      "description": "Live log stream from audit-service via the OTel collector.",
      "datasource": {
        "type": "loki",
        "uid": "medflow-loki"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "medflow-loki"
          },
          "expr": "{service_name=\"audit-service\"} |= ``",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
