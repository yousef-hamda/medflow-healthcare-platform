      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "medflow-prometheus"
          },
          "expr": "time() - max(medflow_audit_worm_export_last_success_timestamp_seconds)",
          "legendFormat": "age",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90000
              },
              {
                "color": "red",
                "value": 180000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
