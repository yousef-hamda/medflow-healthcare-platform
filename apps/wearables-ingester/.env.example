# MedFlow wearables ingester - development defaults (mirror docker-compose.yml)
HTTP_PORT=8092
MQTT_BROKER=mosquitto
MQTT_PORT=1883
DATABASE_URL=postgresql+asyncpg://medflow:medflow_dev_password@postgres:5432/vitals
KAFKA_BROKERS=kafka:9092
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
