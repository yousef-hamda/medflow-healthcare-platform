# MedFlow Audit Service — environment configuration
# Copy to .env and adjust. All platform data is synthetic — no real PHI.

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8095

# ── Postgres (append-only audit_log; UPDATE/DELETE blocked by DB triggers) ────
DATABASE_URL=postgresql://medflow:medflow_dev_password@postgres:5432/audit

# ── Kafka (consumes the "audit.events" topic) ─────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── WORM export to MinIO / S3 (object-lock COMPLIANCE) ────────────────────────
WORM_BUCKET=audit-worm
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_dev_password

# ── OpenTelemetry (OTLP/HTTP; leave blank to disable tracing) ─────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
