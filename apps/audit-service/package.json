{
  "name": "@medflow/audit-service",
  "version": "1.0.0",
  "private": true,
  "description": "MedFlow Audit Service — append-only, hash-chained HIPAA audit log with Kafka ingest and WORM export.",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.600.0",
    "@medflow/shared-types": "workspace:*",
    "@opentelemetry/exporter-trace-otlp-http": "0.51.1",
    "@opentelemetry/resources": "1.24.1",
    "@opentelemetry/sdk-node": "0.51.1",
    "@opentelemetry/semantic-conventions": "1.24.1",
    "fastify": "4.28.1",
    "kafkajs": "2.2.4",
    "pg": "8.12.0",
    "pino": "9.2.0",
    "pino-http": "10.2.0",
    "prom-client": "15.1.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "eslint": "8.57.0",
    "tsx": "4.16.2",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
