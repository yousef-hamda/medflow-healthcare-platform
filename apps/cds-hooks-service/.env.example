# CDS Hooks Service — environment configuration
# Copy to .env and fill in real values (never commit .env)

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8096

# ── Upstream services ─────────────────────────────────────────────────────────
# ML model-serving gRPC/HTTP sidecar
ML_SERVING_URL=http://ml-serving:8094

# FHIR R4 base URL (used when prefetch is absent or incomplete)
FHIR_BASE_URL=http://fhir-server:8090/fhir

# ── Postgres (feedback persistence) ───────────────────────────────────────────
# Uses the monorepo shared Postgres instance.
# Change the DB name to "cds" if you provision a dedicated database:
#   CREATE DATABASE cds OWNER medflow;
DATABASE_URL=postgresql://medflow:medflow_dev_password@postgres:5432/gateway

# Alternative with a dedicated "cds" database:
# DATABASE_URL=postgresql://medflow:medflow_dev_password@postgres:5432/cds

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Collector endpoint (OTLP/HTTP); leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Optional ──────────────────────────────────────────────────────────────────
# Node environment ("development" | "production" | "test")
NODE_ENV=development

# Log level for pino ("trace" | "debug" | "info" | "warn" | "error" | "fatal")
LOG_LEVEL=info

# Upstream fetch timeout in milliseconds
UPSTREAM_TIMEOUT_MS=5000
