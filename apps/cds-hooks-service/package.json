{
  "name": "@medflow/cds-hooks-service",
  "version": "1.0.0",
  "private": true,
  "description": "MedFlow CDS Hooks 1.1 service — sepsis early-warning and readmission-risk decision support, backed by ML serving and FHIR prefetch.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@medflow/fhir-types": "workspace:*",
    "@medflow/shared-types": "workspace:*",
    "@fastify/cors": "11.2.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "fastify": "5.8.5",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
