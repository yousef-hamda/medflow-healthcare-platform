{
  "name": "@medflow/api-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "MedFlow API Gateway — NestJS 10 service providing OAuth2/OIDC, FHIR proxy, ML inference, analytics, and clinical workflow endpoints",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts"
  },
  "dependencies": {
    "@medflow/fhir-types": "workspace:*",
    "@medflow/shared-types": "workspace:*",
    "@nestjs/apollo": "12.1.0",
    "@nestjs/common": "10.3.9",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.3.9",
    "@nestjs/graphql": "12.1.0",
    "@nestjs/mapped-types": "2.0.5",
    "@nestjs/platform-express": "10.3.9",
    "@nestjs/swagger": "7.3.1",
    "@nestjs/throttler": "5.1.2",
    "@nestjs/typeorm": "10.0.2",
    "@apollo/server": "4.10.4",
    "@opentelemetry/auto-instrumentations-node": "0.46.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.51.1",
    "@opentelemetry/sdk-node": "0.51.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "graphql": "16.8.2",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "nestjs-pino": "4.1.0",
    "pg": "8.12.0",
    "pino": "9.2.0",
    "pino-http": "10.2.0",
    "pino-pretty": "11.2.1",
    "prom-client": "15.1.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.20",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.26",
    "@swc/core": "1.15.41",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "1.4.11",
    "@types/node": "25.9.3",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.5.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.8"
  }
}
