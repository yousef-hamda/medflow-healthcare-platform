# ============================================================
# MedFlow API Gateway — environment variables
# Copy to .env and fill in secrets before running locally.
# All dev defaults below match docker-compose.dev.yml.
# ============================================================

# Server
HTTP_PORT=4000
NODE_ENV=development

# PostgreSQL (TypeORM)
DATABASE_URL=postgresql://medflow:medflow_dev_password@postgres:5432/gateway

# FHIR R4 upstream server (HAPI FHIR or Blaze)
FHIR_BASE_URL=http://fhir-server:8090/fhir

# ML serving (FastAPI)
ML_SERVING_URL=http://ml-serving:8094

# Trino (OMOP analytics)
TRINO_URL=http://trino:8080

# Audit microservice
AUDIT_SERVICE_URL=http://audit-service:8095

# De-identification service
DEID_SERVICE_URL=http://deid-service:8093

# Redis (throttler, cache, break-glass store, ML cache)
REDIS_URL=redis://redis:6379

# HashiCorp Vault (Transit encryption for PHI fields)
VAULT_ADDR=http://vault:8200
# !! REQUIRED in production — rotate regularly !!
VAULT_TOKEN=dev-root-token

# OIDC / JWT
# In production replace with RS256 keys — see README auth section.
OIDC_ISSUER=http://localhost:4000
JWT_SIGNING_KEY=change-me-in-production-min-32-chars

# MLflow model registry
MLFLOW_URL=http://mlflow:5000

# OpenTelemetry collector (OTLP over HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=api-gateway
