# MedFlow patient mobile — environment
# Copy to .env (gitignored). Only EXPO_PUBLIC_* vars are embedded in the JS bundle —
# never put secrets in EXPO_PUBLIC_* variables.

# API gateway base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Demo OAuth client id used for the password/refresh grants
EXPO_PUBLIC_OAUTH_CLIENT_ID=medflow-patient-mobile

# Minutes are NOT configurable for the biometric re-lock window (fixed at 2 min,
# see src/lib/lock.ts) — listed here for documentation only.
