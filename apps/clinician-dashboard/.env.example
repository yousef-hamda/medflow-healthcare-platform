# MedFlow clinician dashboard — public runtime configuration.
# All values point at local MedFlow services. All data is synthetic.

# API gateway (OAuth, FHIR proxy, ML, analytics, admin).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Realtime gateway (Socket.IO: sepsis-alert, vitals-update, prediction).
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001

# CDS Hooks service (discovery at /cds-services).
NEXT_PUBLIC_CDS_URL=http://localhost:8096
