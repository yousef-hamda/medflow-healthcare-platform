# MedFlow De-Identification Service — environment configuration
# Copy to .env and adjust. All platform data is synthetic — no real PHI.

# HTTP server port
HTTP_PORT=8093

# Audit service base URL (the "/v1/events" path is appended automatically).
AUDIT_SERVICE_URL=http://audit-service:8095

# Bounded audit retry queue (events are dropped, never block, when full)
AUDIT_QUEUE_SIZE=1000
AUDIT_RETRY_ATTEMPTS=3

# Keyed secret for the deterministic per-patient date shift AND identifier
# pseudonyms (HMAC-SHA256). MUST be a long random secret in production —
# anyone with this secret can recover the date offset.
DATE_SHIFT_SECRET=change-me-to-a-long-random-secret-before-deploying

# OpenTelemetry OTLP/HTTP exporter endpoint (leave blank to disable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# structlog level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
