# MedFlow ml-serving - development defaults (match docker-compose.yml).
# All values are dev-only; production injects these from Vault.

HTTP_PORT=8094

# MLflow model registry + MinIO artifact store
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_dev_password

# Feast online store
FEAST_REDIS_HOST=redis
FEAST_REDIS_PORT=6379

# Append-only predictions log
DATABASE_URL=postgresql+asyncpg://medflow:medflow_dev_password@postgres:5432/predictions
KAFKA_BROKERS=kafka:9092
PREDICTIONS_TOPIC=predictions

# Canary routing (stable hash split on patient_id)
CANARY_ENABLED=false
CANARY_MODEL_VERSION=
CANARY_PERCENT=10

# Salt for one-way patient id hashing in logs/persistence (never log raw ids)
HASH_SALT=medflow-dev-hash-salt

# Registered model names + stage
SEPSIS_MODEL_NAME=sepsis-ews
READMISSION_MODEL_NAME=readmission-30d
XRAY_MODEL_NAME=chest-xray-14
MODEL_STAGE=Production

# Serve documented rule-based scores when the registry is empty
COLD_START_ENABLED=true
