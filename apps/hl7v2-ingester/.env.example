# MedFlow HL7v2 Ingester — example environment.
# All values below are development-only defaults. No real PHI is ever processed.

# HTTP port for the actuator/health endpoints.
SERVER_PORT=8097

# MLLP listen port for inbound HL7v2 messages.
MLLP_PORT=2575

# Base URL of the MedFlow FHIR server used for conditional-create writes.
FHIR_BASE_URL=http://fhir-server:8090/fhir

# Kafka brokers used to mirror raw HL7 messages onto the hl7.raw topic.
KAFKA_BROKERS=kafka:9092

# OpenTelemetry OTLP/HTTP collector endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
