# MedFlow FHIR Server — example environment.
# All values below are development-only defaults. No real PHI is ever processed.

# HTTP port the FHIR REST API and actuator listen on.
SERVER_PORT=8090

# PostgreSQL datasource (database name: fhir).
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fhir
SPRING_DATASOURCE_USERNAME=medflow
SPRING_DATASOURCE_PASSWORD=medflow_dev_password

# Kafka brokers used to publish resource-change events to the fhir.changes topic.
KAFKA_BROKERS=kafka:9092

# Audit service base URL (audit events are posted here asynchronously).
AUDIT_SERVICE_URL=http://audit-service:8095

# OpenTelemetry OTLP/HTTP collector endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
