# MedFlow ml-batch - development defaults (match docker-compose.yml).
# All values are dev-only; production injects these from Vault.
# All data processed by these jobs is SYNTHETIC (Synthea + NIH ChestX-ray14
# research-use-only). No PHI is present.

# ── MLflow tracking + model registry ─────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ── MinIO / S3 credentials (lakehouse + drift-report buckets) ────────────────
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_dev_password
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000

# ── Delta lakehouse layout ───────────────────────────────────────────────────
# Spark reads/writes Delta tables over the s3a:// scheme against this endpoint.
DELTA_S3_ENDPOINT=http://minio:9000
LAKEHOUSE_BUCKET=lakehouse
GOLD_PREFIX=gold
FEATURE_STORE_PREFIX=feature_store
DRIFT_REPORTS_BUCKET=drift-reports

# ── Spark (client/driver submits to the external master) ─────────────────────
SPARK_MASTER=spark://spark-master:7077
SPARK_APP_NAME=medflow-ml
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=4g

# ── Feast feature store ──────────────────────────────────────────────────────
FEAST_REPO_PATH=/workspace/ml/feature_repo
FEAST_REDIS_HOST=redis
FEAST_REDIS_PORT=6379

# ── Predictions log (read-only for the drift job) ────────────────────────────
PREDICTIONS_DATABASE_URL=postgresql+psycopg2://medflow:medflow_dev_password@postgres:5432/predictions

# ── NIH ChestX-ray14 local mirror (RESEARCH USE ONLY) ────────────────────────
# Point this at a local mirror containing Data_Entry_2017.csv + images.
# The dataset is research-use-only; this repo ships no images.
CHESTXRAY_DIR=/data/chestxray14

# ── Registered model names (must match ml-serving) ───────────────────────────
SEPSIS_MODEL_NAME=sepsis-ews
READMISSION_MODEL_NAME=readmission-30d
XRAY_MODEL_NAME=chest-xray-14

# ── Reproducibility ──────────────────────────────────────────────────────────
RANDOM_SEED=42
