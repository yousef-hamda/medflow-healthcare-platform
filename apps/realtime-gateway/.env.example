# HTTP server port
HTTP_PORT=4001

# Kafka bootstrap brokers (comma-separated)
KAFKA_BROKERS=kafka:9092

# URL of the api-gateway service (for care-team membership checks)
API_GATEWAY_URL=http://api-gateway:4000

# HS256 signing key for Socket.IO JWT verification (minimum 32 chars)
JWT_SIGNING_KEY=change-me-to-a-long-random-secret-before-deploying

# Redis connection URL (used for ring buffer + event replay)
REDIS_URL=redis://redis:6379

# OpenTelemetry OTLP exporter endpoint (optional; leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Node environment (development | production)
NODE_ENV=development

# Pino log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
